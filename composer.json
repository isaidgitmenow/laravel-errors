{
    "name": "isaidgitmenow/laravel-errors",
    "description": "Enterprise-grade, highly configurable error handling for Laravel 13.",
    "keywords": [
        "laravel",
        "error-handling",
        "exceptions",
        "filament",
        "inertia",
        "livewire"
    ],
    "homepage": "https://github.com/isaidgitmenow/laravel-errors",
    "license": "MIT",
    "authors": [
        {
            "name": "isaidgitmenow",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "suggest": {
        "barryvdh/laravel-debugbar": "Required for Debugbar integration.",
        "filament/filament": "Required for Filament panel integration.",
        "livewire/livewire": "Required for Livewire component integration.",
        "inertiajs/inertia-laravel": "Required for Inertia.js integration.",
        "sentry/sentry-laravel": "Required for Sentry integration.",
        "spatie/laravel-ignition": "Required for Ignition debug mode integration."
    },
    "autoload": {
        "psr-4": {
            "Isaidgitmenow\\LaravelErrors\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Isaidgitmenow\\LaravelErrors\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Isaidgitmenow\\LaravelErrors\\ErrorsServiceProvider"
            ],
            "aliases": {
                "LaravelErrors": "Isaidgitmenow\\LaravelErrors\\Facades\\LaravelErrors"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
